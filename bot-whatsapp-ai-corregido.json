    {
      "parameters": {
        "jsCode": "// Actualiza el historial de conversacion\nconst prevRaw = $('Cargar  historial  de conversacion').item.json.value || '[]';\nconst history = JSON.parse(prevRaw);\n\nhistory.push({ role: 'user',      content: $('Preparar datos AI').item.json.mensaje });\nhistory.push({ role: 'assistant', content: $('AI Agent').item.json.output });\n\n// Mantiene solo los ultimos 10 mensajes (5 turnos)\nconst trimmed = history.slice(-10);\n\nreturn [{\n  json: {\n    historyJson: JSON.stringify(trimmed),\n    aiResponse:  $('AI Agent').item.json.output,\n    from:        $('Preparar datos AI').item.json.from\n  }\n}];"
      },
