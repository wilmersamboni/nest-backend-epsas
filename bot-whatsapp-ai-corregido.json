    {
      "parameters": {
        "jsCode": "// Normaliza JWT y mensaje desde cualquier camino\nconst from = $('Extraer datos del mensaje').item.json.from;\nconst originalText = $('Extraer datos del mensaje').item.json.text;\n\n// JWT: sesion activa o login reciente\nlet jwt = $('Verificar  sesion JWT').item.json.value || null;\n\nif (\\!jwt) {\n  try {\n    jwt = $('Autenticar aprendiz').item.json.token;\n  } catch(e) { jwt = null; }\n}\n\n// Mensaje: pending intent si existe, si no el texto original\nlet mensaje = originalText;\ntry {\n  const pending = $('Recuperar intencion pendiente').item.json.value;\n  if (pending && pending.trim() \\!== '') mensaje = pending;\n} catch(e) {}\n\nreturn [{ json: { jwt, mensaje, from } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
